{
  "name": "flowace",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise employee monitoring platform (admin-only).",
  "workspaces": [
    "shared",
    "backend",
    "dashboard",
    "agent"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace shared",
    "dev:backend": "npm run dev --workspace backend",
    "dev:dashboard": "npm run dev --workspace dashboard",
    "dev:agent": "npm run dev --workspace agent",
    "dev": "npm-run-all --parallel dev:backend dev:dashboard",
    "build": "npm run build:shared && npm-run-all --parallel \"build --workspace backend\" \"build --workspace dashboard\"",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "lint": "npm-run-all --parallel \"lint --workspace dashboard\" \"lint --workspace backend\""
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
