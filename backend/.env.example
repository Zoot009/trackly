# Backend environment (copy to .env)
NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgresql://flowace:flowace@localhost:5432/flowace

# Auth secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-admin-secret
JWT_EXPIRES_IN=12h
AGENT_TOKEN_SECRET=change-me-agent-secret

# Storage + URLs
UPLOADS_DIR=./uploads/screenshots
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
