# Copy to docker/.env before running docker compose.

# ---- Domain + TLS (Caddy auto-obtains the cert) ----
TRACKLY_DOMAIN=tracker.zootcloud.com
ACME_EMAIL=you@zootcloud.com

# ---- Public URLs ----
PUBLIC_BASE_URL=https://tracker.zootcloud.com
# Dashboard origin(s) allowed for CORS + sockets (comma-separated).
# Use your Vercel/dashboard URL in prod; localhost is fine while testing.
CORS_ORIGIN=https://app.zootcloud.com,http://localhost:3000

# ---- Secrets (generate with: openssl rand -hex 32) ----
JWT_SECRET=change-me
AGENT_TOKEN_SECRET=change-me

# ---- Database: Supabase ----
# Pooled (pgbouncer, :6543) for the app; direct (:5432) for migrations.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ---- (Legacy) bundled Postgres — only used by docker-compose.yml, not prod ----
POSTGRES_USER=trackly
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trackly
