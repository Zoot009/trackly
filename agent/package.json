{
  "name": "@flowace/agent",
  "version": "1.0.0",
  "private": true,
  "description": "Trackly desktop monitoring agent (Electron).",
  "author": "Trackly <support@trackly.dev>",
  "homepage": "https://tracker.zootcloud.com",
  "main": "dist/main/index.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "dev": "npm run build:ts && electron .",
    "start": "electron .",
    "dist": "npm run build:ts && electron-builder",
    "dist:win": "npm run build:ts && electron-builder --win",
    "dist:mac": "npm run build:ts && electron-builder --mac",
    "dist:linux": "npm run build:ts && electron-builder --linux"
  },
  "dependencies": {
    "@flowace/shared": "*",
    "active-win": "^7.7.2",
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.2.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "form-data": "^4.0.1",
    "sharp": "^0.33.5",
    "socket.io-client": "^4.8.1",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "24.13.3",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.trackly.agent",
    "productName": "Trackly",
    "electronVersion": "33.2.1",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "assets/**/*", "static/**/*"],
    "asarUnpack": ["**/node_modules/sharp/**", "**/node_modules/@img/**"],
    "win": { "target": ["nsis"], "artifactName": "Trackly-Setup.${ext}" },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity",
      "artifactName": "Trackly.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "artifactName": "Trackly.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "runAfterFinish": true,
      "allowElevation": true
    },
    "publish": [{ "provider": "generic", "url": "https://tracker.zootcloud.com/downloads" }]
  }
}
